# CaptureMate AI 환경변수 템플릿
# 이 파일을 복사해 .env 를 만든 뒤 실제 값을 채우세요.
#   Windows(PowerShell):  Copy-Item .env.example .env
# .env 는 .gitignore에 등록돼 있어 커밋되지 않습니다. 실제 키는 절대 커밋 금지.

# ── LLM ─────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# 비우면 LLM 대신 키워드 폴백으로 동작(서버는 정상 기동).
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
# Gemini 호출 간 최소 간격(ms). 무료 티어 레이트리밋 완화용. 0=비활성.
#   무료 티어 예: 4000 (분당 약 15회).
LLM_MIN_INTERVAL_MS=4000

# ── 임베딩(유사 스크린샷 그룹핑) ─────────────────────
LLM_EMBEDDING_MODEL=text-embedding-004
# cosine × 시간가중 >= threshold 이면 같은 그룹
GROUPING_THRESHOLD=0.7
# 시간 가중치 감쇠 특성시간(초). 클수록 시간 영향 약화
GROUPING_TAU_SECONDS=300
# 시간 가중치 하한(0~1). 0.6~0.8이면 시간 멀어도 텍스트 유사하면 묶임
GROUPING_W_MIN=0

# ── 마스킹 강화(선택) ────────────────────────────────
# 이름/주소 등 자유형 PII를 Presidio(NER)로 추가 탐지. true로 켜려면:
#   pip install -r requirements-ner.txt && python -m spacy download ko_core_news_sm
USE_PRESIDIO=true

# Kakao Local API. Used to enrich restaurant OCR results with address, coordinates, and place ID.
KAKAO_REST_API_KEY=
KAKAO_TIMEOUT_SECONDS=3

# ── 인증 ─────────────────────────────────────────────
# Android OAuth client ID가 아니라 Google ID token 검증용 Web client ID.
GOOGLE_WEB_CLIENT_ID=
# 운영에서는 32바이트 이상 랜덤 문자열을 사용하고, AWS Secrets Manager에 저장.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ISSUER=capturemate-api
JWT_AUDIENCE=capturemate-android
# Access 30분, Refresh 72시간.
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=259200

# ── OCR 운영 ─────────────────────────────────────────
# true면 서버 시작 시 PaddleOCR 모델을 미리 로드하고 /health/ready로 준비 상태를 노출.
OCR_WARMUP_ON_STARTUP=true
# Fargate task 내부 CPU 경합을 줄이기 위한 PaddleOCR thread 수.
PADDLE_CPU_THREADS=2
